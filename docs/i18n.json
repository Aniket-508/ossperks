{
  "$schema": "https://lingo.dev/schema/i18n.json",
  "version": "1.10",
  "locale": {
    "source": "en",
    "targets": ["es", "zh-CN", "fr", "de", "pt-BR", "ja", "ko", "ru"]
  },
  "buckets": {
    "markdown": {
      "include": [
        "content/cli/[locale]/**/*.mdx",
        "content/programs/[locale]/**/*.mdx"
      ]
    },
    "ts": {
      "include": [
        "src/locales/[locale]/common.ts",
        "src/locales/[locale]/home.ts",
        "src/locales/[locale]/programs.ts"
      ]
    }
  }
}
