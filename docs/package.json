{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm generate:programs && next build",
    "dev": "pnpm --filter @ossperks/data generate && pnpm generate:programs && next dev",
    "start": "next start",
    "generate:programs": "node scripts/generate-programs-mdx.mjs",
    "generate:i18n": "pnpm generate:programs && npx lingo.dev@latest run",
    "i18n:run": "npx lingo.dev@latest run",
    "i18n:init": "npx lingo.dev@latest init",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@octokit/rest": "^22.0.1",
    "@orama/tokenizers": "^3.1.18",
    "@ossperks/core": "workspace:*",
    "@ossperks/data": "workspace:*",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-hotkeys": "^0.8.4",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "ai": "^6.0.138",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "16.6.17",
    "fumadocs-mdx": "14.2.10",
    "fumadocs-ui": "16.6.17",
    "geist": "^1.7.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "nuqs": "^2.8.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.0.8",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "catalog:",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "catalog:"
  }
}
