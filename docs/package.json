{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/generate-programs-mdx.mjs",
    "build": "next build",
    "dev": "pnpm generate:programs && next dev",
    "start": "next start",
    "generate:programs": "node scripts/generate-programs-mdx.mjs",
    "generate:i18n": "pnpm generate:programs && npx lingo.dev@latest run",
    "i18n:run": "npx lingo.dev@latest run",
    "i18n:init": "npx lingo.dev@latest init",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@ossperks/data": "workspace:*",
    "@takumi-rs/image-response": "^0.71.7",
    "fumadocs-core": "16.6.16",
    "fumadocs-mdx": "14.2.9",
    "fumadocs-ui": "16.6.16",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "catalog:",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "catalog:"
  }
}
