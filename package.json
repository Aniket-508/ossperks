{
  "name": "ossperks-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --filter './packages/*' dev",
    "build": "pnpm -r --filter './packages/*' build",
    "clean": "pnpm -r --filter './packages/*' clean",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "test": "pnpm -r --filter './packages/*' test",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "generate:readme": "tsx scripts/generate-readme.ts",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "ultracite": "7.3.1"
  },
  "engines": {
    "node": ">=22.20.0",
    "pnpm": ">=10.29.1"
  },
  "packageManager": "pnpm@10.29.1"
}
