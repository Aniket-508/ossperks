{
  "name": "@ossperks/core",
  "version": "0.1.0",
  "private": true,
  "description": "Core data, types, and eligibility checking logic for OSS Perks.",
  "keywords": [
    "data",
    "eligibility",
    "open-source",
    "oss",
    "perks"
  ],
  "homepage": "https://github.com/Aniket-508/awesome-oss-perks/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/Aniket-508/awesome-oss-perks/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aniket-508/awesome-oss-perks.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./src/schema.ts",
      "default": "./src/schema.ts"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "generate": "tsx src/generate-programs.ts",
    "generate:watch": "tsx src/generate-programs.ts --watch",
    "build": "pnpm generate && pnpm clean && NODE_ENV=production tsdown",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "pnpm generate && tsc -p tsconfig.json --pretty",
    "test": "pnpm build && vitest run",
    "validate": "tsx src/validate.ts"
  },
  "dependencies": {
    "@gitbeaker/rest": "^43.8.0",
    "@octokit/rest": "^22.0.1",
    "license-similarity": "^0.2.3",
    "spdx-license-list": "^6.11.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.20.0",
    "pnpm": ">=10.29.1"
  },
  "packageManager": "pnpm@10.29.1"
}
