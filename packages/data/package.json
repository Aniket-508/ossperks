{
  "name": "@ossperks/data",
  "version": "0.1.0",
  "private": true,
  "description": "OSS Perks program records (JSON), schema, slug rules, and parsed program catalog.",
  "keywords": [
    "data",
    "open-source",
    "oss",
    "perks"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aniket-508/awesome-oss-perks.git",
    "directory": "packages/data"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./src/schema.ts",
      "default": "./src/schema.ts"
    }
  },
  "scripts": {
    "build": "pnpm generate",
    "generate": "tsx src/generate-programs.ts",
    "generate:watch": "tsx src/generate-programs.ts --watch",
    "typecheck": "pnpm generate && tsc -p tsconfig.json --pretty",
    "test": "pnpm generate && vitest run"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.20.0",
    "pnpm": ">=10.29.1"
  },
  "packageManager": "pnpm@10.29.1"
}
