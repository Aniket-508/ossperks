{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@ossperks/data": ["packages/data/src/index.ts"],
      "@ossperks/data/schema": ["packages/data/src/schema.ts"]
    },
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true
  }
}
